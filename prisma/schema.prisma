// Prisma Schema for Skill Marketplace
// 数据库：PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================
// 用户模型
// ===========================================
model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  avatar        String?
  department    String?
  employeeId    String?   // 工号
  provider      String?   // 登录渠道，例如 google
  providerAccountId String? // 第三方账号 ID（例如 Google sub）
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // 关联关系
  skills        Skill[]   @relation("AuthorSkills")
  downloads     Download[]
  comments      Comment[]
  commentLikes  CommentLike[]
  feedbackThreads FeedbackThread[]
  feedbackReplies FeedbackReply[]
  feedbackVotes FeedbackVote[]
  feedbackReplyVotes FeedbackReplyVote[]
  eventLogs     EventLog[]
  
  @@unique([provider, providerAccountId])
  @@map("users")
}

// ===========================================
// 技能分类模型
// ===========================================
model SkillCategory {
  id            String    @id @default(uuid())
  slug          String    @unique
  name          String    @unique
  icon          String?
  sortOrder     Int       @default(0)
  status        String    @default("active") // active, inactive
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 关联关系
  skills        Skill[]
  eventLogs     EventLog[]

  @@index([sortOrder])
  @@map("skill_categories")
}

// ===========================================
// 技能包模型
// ===========================================
model Skill {
  id            String    @id @default(uuid())
  title         String
  summary       String?   @db.Text // 功能简介（新上传强制填写 >= 10 字）
  description   String    @db.Text
  categoryId    String?   // 分类 ID（预留扩展）
  category      SkillCategory? @relation(fields: [categoryId], references: [id])
  tags          String[]  // 标签数组
  fileName      String    // OSS 文件名
  fileSize      Int       // 文件大小（字节）
  fileType      String    // 文件类型：zip, tar.gz, rar, 7z
  downloadCount Int       @default(0)
  viewCount     Int       @default(0)
  status        String    @default("active") // active, archived, deleted
  authorId      String
  author        User      @relation("AuthorSkills", fields: [authorId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // 关联关系
  fileBlob      SkillFileBlob?
  downloads     Download[]
  comments      Comment[]
  eventLogs     EventLog[]
  
  // 索引优化
  @@index([title])
  @@index([tags])
  @@index([authorId])
  @@index([categoryId])
  @@index([categoryId, createdAt])
  @@map("skills")
}

model SkillFileBlob {
  id            String    @id @default(uuid())
  skillId       String    @unique
  fileData      Bytes
  originalName  String
  mimeType      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  skill         Skill     @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@map("skill_file_blobs")
}

// ===========================================
// 下载记录模型
// ===========================================
model Download {
  id            String    @id @default(uuid())
  userId        String
  skillId       String
  downloadedAt  DateTime  @default(now())
  
  // 关联关系
  user          User      @relation(fields: [userId], references: [id])
  skill         Skill     @relation(fields: [skillId], references: [id])
  
  // 唯一约束（同一用户对同一技能包的重复下载只记录一次）
  @@unique([userId, skillId])
  @@index([userId])
  @@index([skillId])
  @@map("downloads")
}

// ===========================================
// 评论模型（预留扩展）
// ===========================================
model Comment {
  id            String    @id @default(uuid())
  content       String    @db.Text
  rating        Int?      // 评分 1-5
  likeCount     Int       @default(0)
  userId        String
  skillId       String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // 关联关系
  user          User      @relation(fields: [userId], references: [id])
  skill         Skill     @relation(fields: [skillId], references: [id])
  images        CommentImage[]
  likes         CommentLike[]
  
  @@index([skillId])
  @@index([userId])
  @@index([skillId, likeCount])
  @@index([skillId, createdAt])
  @@map("comments")
}

model CommentImage {
  id            String    @id @default(uuid())
  commentId     String
  url           String
  fileName      String?
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())

  comment       Comment   @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId, sortOrder])
  @@map("comment_images")
}

model CommentLike {
  id            String    @id @default(uuid())
  commentId     String
  userId        String
  createdAt     DateTime  @default(now())

  comment       Comment   @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([userId])
  @@map("comment_likes")
}

model FeedbackThread {
  id            String    @id @default(uuid())
  title         String
  content       String    @db.Text
  status        String    @default("open") // open, closed
  upvoteCount   Int       @default(0)
  downvoteCount Int       @default(0)
  replyCount    Int       @default(0)
  pinnedReplyId String?
  userId        String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies       FeedbackReply[] @relation("ThreadReplies")
  pinnedReply   FeedbackReply?  @relation("PinnedFeedbackReply", fields: [pinnedReplyId], references: [id], onDelete: SetNull)
  votes         FeedbackVote[]

  @@index([createdAt])
  @@index([upvoteCount, createdAt])
  @@index([userId, createdAt])
  @@index([pinnedReplyId])
  @@map("feedback_threads")
}

model FeedbackReply {
  id            String    @id @default(uuid())
  content       String    @db.Text
  threadId      String
  parentId      String?
  userId        String
  upvoteCount   Int       @default(0)
  downvoteCount Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  thread        FeedbackThread @relation("ThreadReplies", fields: [threadId], references: [id], onDelete: Cascade)
  parent        FeedbackReply? @relation("FeedbackReplyToParent", fields: [parentId], references: [id], onDelete: SetNull)
  children      FeedbackReply[] @relation("FeedbackReplyToParent")
  pinnedByThread FeedbackThread[] @relation("PinnedFeedbackReply")
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes         FeedbackReplyVote[]

  @@index([threadId, createdAt])
  @@index([parentId])
  @@index([userId, createdAt])
  @@map("feedback_replies")
}

model FeedbackVote {
  id            String    @id @default(uuid())
  threadId      String
  userId        String
  value         Int       // 1: 赞, -1: 踩
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  thread        FeedbackThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@index([userId])
  @@index([threadId, value])
  @@map("feedback_votes")
}

model FeedbackReplyVote {
  id            String    @id @default(uuid())
  replyId       String
  userId        String
  value         Int       // 1: 赞, -1: 踩
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  reply         FeedbackReply @relation(fields: [replyId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([replyId, userId])
  @@index([userId])
  @@index([replyId, value])
  @@map("feedback_reply_votes")
}

model EventLog {
  id            String          @id @default(uuid())
  eventName     String
  page          String?
  module        String?
  action        String?
  userId        String?
  skillId       String?
  categoryId    String?
  sessionId     String?
  anonymousId   String?
  metadata      Json?
  createdAt     DateTime        @default(now())

  user          User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  skill         Skill?          @relation(fields: [skillId], references: [id], onDelete: SetNull)
  category      SkillCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([eventName, createdAt])
  @@index([userId, createdAt])
  @@index([skillId, createdAt])
  @@index([categoryId, createdAt])
  @@map("event_logs")
}
