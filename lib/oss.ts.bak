/**
 * 阿里云 OSS 文件操作工具
 * 
 * 提供文件上传、下载、删除等功能
 */

import OSS from 'ali-oss';

// OSS 配置
const ossConfig = {
  region: process.env.OSS_REGION || 'oss-cn-hangzhou',
  accessKeyId: process.env.OSS_ACCESS_KEY_ID,
  accessKeySecret: process.env.OSS_ACCESS_KEY_SECRET,
  bucket: process.env.OSS_BUCKET || 'skill-marketplace',
};

// 创建 OSS 客户端实例
export function getOSSClient() {
  if (!ossConfig.accessKeyId || !ossConfig.accessKeySecret) {
    throw new Error('OSS 配置缺失，请检查环境变量');
  }

  return new OSS(ossConfig);
}

// ===========================================
// 文件上传
// ===========================================
export async function uploadFile(
  fileBuffer: Buffer,
  fileName: string,
  mimeType?: string
): Promise<{
  url: string;
  fileName: string;
  fileSize: number;
}> {
  const client = getOSSClient();

  // 生成唯一的 OSS 对象键（按日期分类）
  const date = new Date();
  const yearMonth = `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}`;
  const objectKey = `skills/${yearMonth}/${fileName}`;

  try {
    const result = await client.put(objectKey, fileBuffer, {
      headers: {
        'Content-Type': mimeType || 'application/octet-stream',
      },
    });

    return {
      url: result.url,
      fileName: objectKey,
      fileSize: result.size || fileBuffer.length,
    };
  } catch (error: any) {
    console.error('OSS 上传失败:', error);
    throw new Error(`文件上传失败：${error.message}`);
  }
}

// ===========================================
// 文件下载（获取临时访问 URL）
// ===========================================
export async function getFileUrl(fileName: string, expiresIn = 3600): Promise<string> {
  const client = getOSSClient();

  try {
    const url = client.signatureUrl(fileName, {
      expires: expiresIn,
    });
    return url;
  } catch (error: any) {
    console.error('获取文件 URL 失败:', error);
    throw new Error(`获取下载链接失败：${error.message}`);
  }
}

// ===========================================
// 删除文件
// ===========================================
export async function deleteFile(fileName: string): Promise<void> {
  const client = getOSSClient();

  try {
    await client.delete(fileName);
  } catch (error: any) {
    console.error('删除文件失败:', error);
    throw new Error(`删除文件失败：${error.message}`);
  }
}

// ===========================================
// 批量删除文件
// ===========================================
export async function deleteFiles(fileNames: string[]): Promise<void> {
  const client = getOSSClient();

  try {
    await client.deleteMulti(fileNames);
  } catch (error: any) {
    console.error('批量删除文件失败:', error);
    throw new Error(`批量删除文件失败：${error.message}`);
  }
}

// ===========================================
// 检查文件是否存在
// ===========================================
export async function fileExists(fileName: string): Promise<boolean> {
  const client = getOSSClient();

  try {
    await client.head(fileName);
    return true;
  } catch (error: any) {
    if (error.code === 'NoSuchKey') {
      return false;
    }
    throw error;
  }
}

// ===========================================
// 获取文件信息
// ===========================================
export async function getFileMeta(fileName: string): Promise<{
  size: number;
  type: string;
  lastModified: string;
}> {
  const client = getOSSClient();

  try {
    const meta = await client.head(fileName);
    return {
      size: meta.size,
      type: meta.type,
      lastModified: meta.lastModified,
    };
  } catch (error: any) {
    console.error('获取文件元数据失败:', error);
    throw new Error(`获取文件信息失败：${error.message}`);
  }
}

// ===========================================
// 验证文件类型
// ===========================================
export const ALLOWED_FILE_TYPES = ['.zip', '.tar.gz', '.rar', '.7z'];
export const MAX_FILE_SIZE_MB = parseInt(process.env.MAX_FILE_SIZE_MB || '50', 10);

export function validateFile(fileName: string, fileSize: number): {
  valid: boolean;
  error?: string;
} {
  // 检查文件扩展名
  const ext = '.' + fileName.split('.').pop()?.toLowerCase();
  if (!ALLOWED_FILE_TYPES.includes(ext)) {
    return {
      valid: false,
      error: `不支持的文件类型：${ext}。允许的类型：${ALLOWED_FILE_TYPES.join(', ')}`,
    };
  }

  // 检查文件大小
  const maxSizeBytes = MAX_FILE_SIZE_MB * 1024 * 1024;
  if (fileSize > maxSizeBytes) {
    return {
      valid: false,
      error: `文件大小超出限制（最大 ${MAX_FILE_SIZE_MB}MB）`,
    };
  }

  return { valid: true };
}
